<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="message"
            type="com.example.chatapptest.database.model.MessageData" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingTop="6dp"
        android:paddingEnd="40dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/sender_avatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_chat_avatar"
            android:contentDescription="@{message.senderDisplayName()}"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@{message.senderInitial()}"
            android:textColor="@color/chat_primary_dark"
            android:textSize="13sp"
            tools:text="A" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@{message.senderDisplayName()}"
                android:textColor="@color/chat_text_secondary"
                android:textSize="12sp"
                tools:text="Attia" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/messageCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardBackgroundColor="@color/chat_received_bubble"
                app:cardCornerRadius="22dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/chat_received_bubble_stroke"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/message_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="420dp"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="@{message.contentText()}"
                    android:textColor="@color/chat_text_primary"
                    android:textSize="15sp"
                    tools:text="This redesigned layout feels cleaner and much easier to scan." />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/date_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@{message.formattime()}"
                android:textColor="@color/chat_text_hint"
                android:textSize="11sp"
                tools:text="09:42 AM" />
        </LinearLayout>
    </LinearLayout>

</layout>
